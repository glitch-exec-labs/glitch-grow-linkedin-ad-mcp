# LinkedIn Marketing API credentials
# Create an app at https://www.linkedin.com/developers/apps
# Request the "Advertising API" product on the app's Products tab.
# OAuth scopes required: r_ads, rw_ads, r_ads_reporting

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# After completing the OAuth dance, paste the tokens you received.
# Refresh token rotates per LinkedIn's policy — keep this updated.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=

# API version — format YYYYMM. Bump when migrating.
# https://learn.microsoft.com/en-us/linkedin/marketing/versioning
LINKEDIN_API_VERSION=202604
